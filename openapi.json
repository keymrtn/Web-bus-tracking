        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "origin_name",
                  "dest_name"
                ],
                "properties": {
                  "origin_name": {
                    "type": "string"
                  },
                  "origin_coords": {
                    "type": "array",
                    "items": {
                      "type": "number"
                    }
                  },
                  "dest_name": {
                    "type": "string"
                  },
                  "dest_coords": {
                    "type": "array",
                    "items": {
                      "type": "number"
                    }
                  },
                  "jarak": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Route created"
          },
          "400": {
            "description": "Validation"
          }
